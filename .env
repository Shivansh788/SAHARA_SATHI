# Copy this file to .env and fill only the keys you want to enable.
# Empty keys are safe: app still works using local/offline fallback.

# Core app
SAHARA_HOST=0.0.0.0
SAHARA_PORT=8501
SAHARA_DB_PATH=sahara.db
SAHARA_TOKEN_SECRET=change-me-before-production
SAHARA_TOKEN_TTL_SECONDS=86400
SAHARA_OTP_TTL_SECONDS=600
SAHARA_DEV_OTP_HINT=false

# Gemini (optional)
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
GEMINI_TIMEOUT_SEC=20

# COEAI (optional, UPESNET only)
COEAI_API_KEY=
COEAI_MODEL=deepseek-r1:70b
COEAI_TIMEOUT_SEC=120
COEAI_HEALTH_TIMEOUT_SEC=10
UPESNET_CONNECTED=false

# Data.gov (optional)
DATA_GOV_PROVIDER=auto
DATA_GOV_API_KEY=
DATA_GOV_RAPIDAPI_KEY=
DATA_GOV_BASE_URL=https://api.data.gov.in
DATA_GOV_RAPIDAPI_BASE_URL=https://data-gov-in.p.rapidapi.com
DATA_GOV_RAPIDAPI_HOST=data-gov-in.p.rapidapi.com
DATA_GOV_TIMEOUT_SEC=8

# OpenAI TTS (optional)
OPENAI_API_KEY=
OPENAI_TTS_MODEL=tts-1
OPENAI_TTS_VOICE=alloy

# Local ollama fallback tuning
OLLAMA_CONNECT_TIMEOUT_SEC=5
OLLAMA_READ_TIMEOUT_SEC=10

# Noise reduction for clean startup logs
HF_HUB_DISABLE_SYMLINKS_WARNING=1
TOKENIZERS_PARALLELISM=false
TRANSFORMERS_VERBOSITY=error
